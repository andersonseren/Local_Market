# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=production

# Database
# Para PostgreSQL en Render (se proporciona automáticamente)
# DATABASE_URL=postgresql://user:password@host:port/database

# Seguridad
# Generar una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_change_in_production

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production

# Debug (solo para desarrollo local)
DEBUG=False

# Render variables (se establecen automáticamente en Render)
# PORT=10000
